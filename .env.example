# =============================================================================
# Quipu — plantilla de variables de entorno
# =============================================================================
#
# Cómo usar:
#   1. Copia este archivo:  cp .env.example .env.local
#   2. Rellena los valores. En desarrollo, Next.js carga `.env.local` solo.
#
# Dónde vive cada variable:
#   • Next.js (cliente y servidor Node):  se lee de `.env.local` y, en
#     producción, de las env vars configuradas en Vercel.
#   • Convex (mutations, queries, Polar, Better Auth, passkey):  se configura
#     en el dashboard de Convex (Settings → Environment Variables) o, en
#     desarrollo, se sincroniza desde `.env.local` mientras corre
#     `npx convex dev`.
#
# Convex NO lee `.env.local` del root por sí solo: solo lee
# `packages/convex/.env.local` (que el CLI mantiene con CONVEX_DEPLOYMENT,
# CONVEX_URL, CONVEX_SITE_URL). Para el resto de vars (Polar, Better Auth,
# passkey, etc.) usa `npx convex env set <NAME> <value>` o setéalas en el
# dashboard.
#
# No subas `.env.local` ni `.env.production` con secretos al repositorio.
# =============================================================================

# ---------------------------------------------------------------------------
# Convex (requerido)
# ---------------------------------------------------------------------------
# URL del despliegue (dev o prod). NEXT_PUBLIC_* llega al bundle del cliente.
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Opcional: Convex CLI / CI (deploy). No es lo mismo que las URLs de arriba.
# CONVEX_DEPLOYMENT=
# CONVEX_DEPLOY_KEY=

# ---------------------------------------------------------------------------
# URL pública de la app (requerido)
# ---------------------------------------------------------------------------
# Una sola fuente de verdad para Better Auth en Convex (baseURL), enlaces
# y SEO. Sin barra final.
# Ej. desarrollo: http://localhost:3000  |  producción: https://tu-dominio.app
SITE_URL=
# En Next.js, lib/env.ts también acepta (en este orden) BETTER_AUTH_URL,
# VERCEL_URL (prefijo https://), y NEXT_PUBLIC_SITE_URL como respaldo.
# Convex no las usa — solo lee SITE_URL.

# ---------------------------------------------------------------------------
# Better Auth (Convex)
# ---------------------------------------------------------------------------
# Secret de firma de JWT. Generar con:  openssl rand -base64 32
BETTER_AUTH_SECRET=

# ---------------------------------------------------------------------------
# Passkey / WebAuthn (Convex)
# ---------------------------------------------------------------------------
# ID del Relying Party. En dev: "localhost". En prod: dominio real SIN esquema
# ni puerto (ej. "quipu.app"). Better Auth lo usa para origin checks.
PASSKEY_RP_ID=localhost
# Nombre humano del RP. Aparece en el prompt del authenticator.
PASSKEY_RP_NAME=Quipu

# ---------------------------------------------------------------------------
# Polar (pagos — Convex: actions / HTTP / Better Auth plugin)
# ---------------------------------------------------------------------------
# Nombre correcto del token (no uses POLAR_ACCESS_TOKEN; no lo lee el código).
POLAR_ORGANIZATION_TOKEN=
# Secret del webhook. Lo encuentras en Polar dashboard → webhooks.
POLAR_WEBHOOK_SECRET=
# sandbox | production
POLAR_SERVER=sandbox
POLAR_PRODUCT_ID_PREMIUM=

# ---------------------------------------------------------------------------
# Resend (email, si lo usas)
# ---------------------------------------------------------------------------
RESEND_API_KEY=

# ---------------------------------------------------------------------------
# PostHog (Next.js — debe ser NEXT_PUBLIC_* para el navegador)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ---------------------------------------------------------------------------
# Sentry
# ---------------------------------------------------------------------------
# Servidor y Edge (Next.js server/edge)
SENTRY_DSN=
# Cliente (navegador)
NEXT_PUBLIC_SENTRY_DSN=
# Tasa de muestreo de trazas (0.0–1.0). Por defecto en código suele ser 0.1
# SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# Subida de source maps en build (plugin Sentry / CI)
# SENTRY_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# E2E (Playwright) — cuenta de prueba dedicada, nunca producción
# ---------------------------------------------------------------------------
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
