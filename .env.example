# =============================================================================
# Quipu — plantilla de variables de entorno
# =============================================================================
#
# Cómo usar:
#   1. Copia este archivo:  cp .env.example .env.local
#   2. Rellena los valores. En desarrollo, Next.js carga `.env.local` solo.
#
# Dónde vive cada cosa:
#   • Next.js (app en el navegador / servidor Node):  .env.local  (y Vercel)
#   • Convex (mutations, queries, Polar, Better Auth en backend):  Dashboard
#     de Convex → Settings → Environment Variables, O las mismas claves en
#     `.env.local` cuando corres `npx convex dev` (Convex las sincroniza al dev).
#
# No subas `.env.local` ni `.env.production` con secretos al repositorio.
# =============================================================================

# ---------------------------------------------------------------------------
# Convex (requerido)
# ---------------------------------------------------------------------------
# URL del despliegue (dev o prod). NEXT_PUBLIC_* llega al bundle del cliente.
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Opcional: Convex CLI / CI (deploy). No es lo mismo que las URLs de arriba.
# CONVEX_DEPLOYMENT=
# CONVEX_DEPLOY_KEY=

# ---------------------------------------------------------------------------
# URL pública de la app (requerido)
# ---------------------------------------------------------------------------
# Una sola fuente de verdad para Better Auth en Convex (baseURL), enlaces
# y SEO (metadataBase, robots.ts, sitemap.ts leen esta variable).
# Ej. desarrollo: http://localhost:3000  |  producción: https://tu-dominio.app
# Sin barra final.
SITE_URL=
# En Next.js, lib/env.ts también acepta (en este orden) BETTER_AUTH_URL,
# VERCEL_URL (prefijo https://), y NEXT_PUBLIC_SITE_URL como respaldo.

# ---------------------------------------------------------------------------
# Better Auth (requerido en Convex)
# ---------------------------------------------------------------------------
BETTER_AUTH_SECRET=

# En este repo, createAuth usa SITE_URL como baseURL en Convex.
# BETTER_AUTH_URL solo haría falta si configuraras Better Auth para leerla;
# no está referenciada en el código TypeScript actual.

# ---------------------------------------------------------------------------
# Polar (pagos — leído en Convex: actions / HTTP / Better Auth plugin)
# ---------------------------------------------------------------------------
# Nombre correcto del token (no uses POLAR_ACCESS_TOKEN; no lo lee el código).
POLAR_ORGANIZATION_TOKEN=
# Alias heredado (convex/runtimeEnv.ts): POLAR_ACCESS_TOKEN
POLAR_WEBHOOK_SECRET=
# sandbox | production
POLAR_SERVER=sandbox
POLAR_PRODUCT_ID_PREMIUM=

# ---------------------------------------------------------------------------
# Resend (email, si lo usas)
# ---------------------------------------------------------------------------
RESEND_API_KEY=

# ---------------------------------------------------------------------------
# PostHog (solo Next.js — debe ser NEXT_PUBLIC_* para el navegador)
# ---------------------------------------------------------------------------
# Resuelto en lib/env.ts: preferir NEXT_PUBLIC_POSTHOG_KEY.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Alias heredado (sigue funcionando si no defines KEY):
# NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=

# ---------------------------------------------------------------------------
# Sentry
# ---------------------------------------------------------------------------
# Servidor y Edge (Next.js server/edge)
SENTRY_DSN=
# Cliente (navegador)
NEXT_PUBLIC_SENTRY_DSN=
# Tasa de muestreo de trazas (0.0–1.0). Por defecto en código suele ser 0.1
# SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# Subida de source maps en build (plugin Sentry / CI)
# SENTRY_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# E2E (Playwright) — cuenta de prueba dedicada, nunca producción
# ---------------------------------------------------------------------------
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
